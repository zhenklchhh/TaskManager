{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Task Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Total Tasks Created",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(tasks_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "Tasks by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "expr": "sum(tasks_total) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "title": "Task Creation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        { "expr": "rate(tasks_total[5m])", "legendFormat": "{{type}} - {{status}}" }
      ]
    },
    {
      "title": "Active Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
      "targets": [
        { "expr": "workers_active", "legendFormat": "Workers" }
      ]
    },
    {
      "title": "Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "title": "Task Processing Duration",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        { "expr": "rate(task_processing_duration_seconds_bucket[5m])", "legendFormat": "{{le}}" }
      ]
    },
    {
      "title": "Tasks Processed per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        { "expr": "rate(worker_tasks_processed_total[1m]) * 60", "legendFormat": "{{worker_id}} - {{status}}" }
      ]
    },
    {
      "title": "Reliability",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "title": "Tasks by Priority",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "targets": [
        { "expr": "tasks_processed_by_priority_total", "legendFormat": "Priority {{priority}}" }
      ]
    },
    {
      "title": "Failed Tasks Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "targets": [
        { "expr": "rate(tasks_total{status=\"failed\"}[5m])", "legendFormat": "Failed rate" }
      ]
    },
    {
      "title": "Semaphore Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        { "expr": "semaphore_slots_available", "legendFormat": "Available slots" },
        { "expr": "rate(semaphore_acquired_total[5m])", "legendFormat": "Acquire rate" }
      ]
    },
    {
      "title": "System Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "title": "DB Connections",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 28 },
      "targets": [
        { "expr": "db_connections_active", "legendFormat": "Active" }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 50,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 45 }
            ]
          }
        }
      }
    },
    {
      "title": "Redis Connections",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 28 },
      "targets": [
        { "expr": "redis_connections_active", "legendFormat": "Active" }
      ]
    },
    {
      "title": "HTTP Response Times (p95)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" }
      ]
    },
    {
      "title": "DB Query Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 34 },
      "targets": [
        { "expr": "rate(db_query_duration_seconds_sum[5m]) / rate(db_query_duration_seconds_count[5m])", "legendFormat": "{{operation}}" }
      ]
    },
    {
      "title": "Scheduler Runs & Errors",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 34 },
      "targets": [
        { "expr": "rate(scheduler_runs_total[5m])", "legendFormat": "Runs" },
        { "expr": "rate(scheduler_errors_total[5m])", "legendFormat": "Errors" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["taskmanager"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "TaskManager Dashboard",
  "uid": "taskmanager-main",
  "version": 1
}
